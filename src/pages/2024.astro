---
import BaseLayout from '../layouts/BaseLayout.astro';
import SessionBlock from '../components/SessionBlock.astro';

const baseUrlRaw = import.meta.env.BASE_URL;
const baseUrl = baseUrlRaw.endsWith('/') ? baseUrlRaw : `${baseUrlRaw}/`;
---

<BaseLayout title="Workshop on Household Heterogeneity, Inflation, and the Green Transition 2024">
  <section class="archive-hero">
    <div class="container">
      <a href={baseUrl} class="archive-hero__back">← Back to 2026</a>
      <p class="archive-hero__edition">First Edition</p>
      <h1>Workshop on Household Heterogeneity, Inflation, and the Green Transition</h1>
      <p class="archive-hero__date">June 6-7, 2024</p>
      <p class="archive-hero__venues">
        Venues: Facoltà di Economia, via del Castro Laurenziano 9, and Facoltà di Scienze Politiche, Sociologia, Comunicazione, piazzale Aldo Moro 5, Rome.
      </p>
      <p class="archive-hero__pdf">
        <a class="archive-hero__pdf-link" href={`${baseUrl}programmes/workshop_6_7_June_Sapienza.pdf`} target="_blank" rel="noopener">
          Official Programme (PDF)
        </a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      
      <!-- Day 1 -->
      <div class="programme-day">
        <h2 class="programme-day__title">
          <span class="programme-day__date">June 6, 2024</span>
          <span class="programme-day__location">Sala Lauree, Facoltà di Economia, via del Castro Laurenziano 9</span>
        </h2>
        
        <div class="programme-day__sessions">
          <SessionBlock 
            time="14:00"
            title="Registration and welcome address"
            isBreak={true}
          />
          
          <div class="session-header">
            <h3>Session 1: The Heterogeneous Effect of Inflation</h3>
            <p class="session-chair">Chair: Cristiano Cantore (Sapienza University of Rome)</p>
          </div>
          
          <SessionBlock 
            time="14:30-15:15"
            title="The Heterogeneous Impact of Inflation on Households' Balance Sheets"
            presenter="Clodomiro Ferreira"
            affiliation="Banco de España"
            coauthors="Miguel Cardoso, José Miguel Leiva, Galo Nuño, Álvaro Ortiz, Tomasa Rodrigo, and Sirenia Vazquez"
            discussant="Francesco Corsello"
            discussantAffiliation="Banca d'Italia"
          />
          
          <SessionBlock 
            time="15:15-16:00"
            title="Shopping behavior and the effect of monetary policy on inflation heterogeneity along the income distribution"
            presenter="Miguel Ampudia"
            affiliation="BIS"
            coauthors="Michael Ehrmann and Georg Strasser (ECB)"
            discussant="Luigi Paciello"
            discussantAffiliation="EIEF"
          />
          
          <SessionBlock 
            time="16:00-16:30"
            title="Coffee Break"
            isBreak={true}
          />
          
          <SessionBlock 
            time="16:30-17:15"
            title="Inflation is not equal for all: the heterogeneous effects of energy shocks"
            presenter="Marianna Riggi"
            affiliation="Banca d'Italia"
            coauthors="F. Corsello"
            discussant="Patrizio Tirelli"
            discussantAffiliation="Università di Pavia"
          />
          
          <SessionBlock 
            time="20:00"
            title="Dinner at La Casa dell'Aviatore (invitation only)"
            isBreak={true}
          />
        </div>
      </div>
      
      <!-- Day 2 -->
      <div class="programme-day">
        <h2 class="programme-day__title">
          <span class="programme-day__date">June 7, 2024</span>
          <span class="programme-day__location">Sala Lauree, Facoltà di Scienze Politiche, Sociologia, Comunicazione, piazzale Aldo Moro 5</span>
        </h2>
        
        <div class="programme-day__sessions">
          <div class="session-header">
            <h3>Session 2: The Heterogeneous Effect of the Green Transition</h3>
            <p class="session-chair">Chair: Salvatore Nisticò (Sapienza University of Rome)</p>
          </div>
          
          <SessionBlock 
            time="09:00-09:45"
            title="Climate Policies, Macroprudential Regulation, and the Welfare Cost of Business Cycles"
            presenter="Barbara Annicchiarico"
            affiliation="Roma Tre University"
            coauthors="Marco Carli (Tor Vergata University) and Francesca Diluiso (Bank of England)"
            discussant="Fabio Di Dio"
            discussantAffiliation="Sapienza University"
          />
          
          <SessionBlock 
            time="09:45-10:30"
            title="Macro Shocks and Inequality"
            presenter="Francesco Furlanetto"
            affiliation="Norges Bank"
            coauthors="Drago Bergholt and Lorenzo Mori"
            discussant="Elisa Guglielminetti"
            discussantAffiliation="Banca d'Italia"
          />
          
          <SessionBlock 
            time="10:30-11:00"
            title="Coffee Break"
            isBreak={true}
          />
          
          <SessionBlock 
            time="11:00-11:45"
            title="Distributional Effects of the Green Transition"
            presenter="Andrea Colciago"
            affiliation="Dutch Central Bank and University of Bicocca"
            coauthors="Guido Ascari, Timo Haber, Stefan Wöhrmüller"
            discussant="Andrey Alexandrov"
            discussantAffiliation="Università di Roma Tor Vergata"
          />
          
          <SessionBlock 
            time="12:00-13:30"
            title="Policy Panel"
            isPanel={true}
            panelists={[
              "Andrea Brandolini (Bank of Italy)",
              "Corrado Pollastri (Parliamentary Budget Office)",
              "Ottavio Ricchi (Director of the Economic and Financial Analysis and Research of the Treasury)"
            ]}
          />
          
          <SessionBlock 
            time="13:30-15:00"
            title="Buffet Lunch"
            isBreak={true}
          />
        </div>
      </div>
      
    </div>
  </section>
</BaseLayout>

<style>
  .archive-hero {
    background: linear-gradient(135deg, var(--color-secondary) 0%, #2d2d4a 100%);
    color: var(--color-white);
    padding: var(--space-3xl) 0;
    text-align: center;
  }
  
  .archive-hero__back {
    display: inline-block;
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
    transition: color var(--transition-fast);
  }
  
  .archive-hero__back:hover {
    color: var(--color-accent-light);
  }
  
  .archive-hero__edition {
    display: inline-block;
    background: rgba(255, 255, 255, 0.1);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: var(--space-xs) var(--space-md);
    border-radius: 4px;
    margin-bottom: var(--space-md);
  }
  
  .archive-hero h1 {
    font-size: 2rem;
    color: var(--color-white);
    margin-bottom: var(--space-sm);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .archive-hero__date {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 var(--space-sm);
  }

  .archive-hero__venues {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 900px;
    margin: 0 auto;
  }

  .archive-hero__pdf {
    margin: var(--space-md) 0 0;
  }

  .archive-hero__pdf-link {
    display: inline-block;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    color: var(--color-white);
    padding: var(--space-xs) var(--space-lg);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .archive-hero__pdf-link:hover {
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-white);
    text-decoration: none;
  }
  
  .programme-day {
    margin-bottom: var(--space-4xl);
  }
  
  .programme-day:last-child {
    margin-bottom: 0;
  }
  
  .programme-day__title {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-primary);
    margin-bottom: var(--space-lg);
  }
  
  .programme-day__date {
    font-size: 1.25rem;
  }
  
  .programme-day__location {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-text-light);
    font-family: var(--font-sans);
  }
  
  .session-header {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
  }
  
  .session-header:first-child {
    margin-top: 0;
    border-top: none;
  }
  
  .session-header h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }
  
  .session-chair {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  
  @media (max-width: 768px) {
    .programme-day__title {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .archive-hero h1 {
      font-size: 1.5rem;
    }
  }
</style>
